# Copy this file to .env and adjust values for your environment.
# Backend DB (Supabase/Postgres example)
DB_URL=jdbc:postgresql://aws-1-eu-west-1.pooler.supabase.com:6543/postgres?sslmode=require
DB_USERNAME=postgres.<your_project_ref>
DB_PASSWORD=<your_db_password>
DB_DRIVER_CLASS=org.postgresql.Driver

# Backend runtime
SQL_INIT_MODE=never
H2_CONSOLE_ENABLED=false
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false

# JWT (Base64-encoded secret, min 32 bytes before encoding)
APP_JWT_SECRET=<base64_secret>
APP_JWT_EXPIRATION_MS=86400000
